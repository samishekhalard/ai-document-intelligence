# ─────────────────────────────────────────────────────────────────────
#  Enterprise AI Document Intelligence Platform — example configuration
# ─────────────────────────────────────────────────────────────────────
# Copy to .env and adjust for your environment.
#   cp .env.example .env
# All values are validated at startup by pydantic-settings. Unknown keys
# are silently ignored.
# ─────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────
# Human-readable name shown in FastAPI docs and Streamlit header.
APP_NAME="Enterprise AI Document Intelligence"

# One of: development, staging, production. Controls default log verbosity
# and whether Uvicorn should auto-reload.
APP_ENV=development

# loguru log level: DEBUG, INFO, WARNING, ERROR, CRITICAL.
LOG_LEVEL=INFO

# ── HTTP API ─────────────────────────────────────────────────────────
# FastAPI bind address. 0.0.0.0 listens on every interface (required
# inside containers); use 127.0.0.1 for local-only dev.
API_HOST=0.0.0.0
API_PORT=8000

# Public URL of the API (used by the Streamlit frontend to discover it).
API_BASE_URL=http://localhost:8000

# ── Local LLM (llama.cpp, CPU-only) ──────────────────────────────────
# Path to the GGUF model file used for answer generation. Download via
# the README instructions — everything stays local, no API key needed.
MODEL_PATH=models/llama-3.2-1b.gguf

# SentenceTransformer model name used for embeddings. Downloaded from
# HuggingFace on first use and cached under ~/.cache/huggingface.
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Context window (tokens) passed to llama.cpp. Larger = more RAM.
LLM_N_CTX=2048

# CPU threads used for generation. Tune to physical core count.
LLM_N_THREADS=4

# Maximum tokens generated per completion.
LLM_MAX_TOKENS=512

# ── Storage paths ────────────────────────────────────────────────────
# Root data directory. Uploads / ChromaDB / SQLite all default under it.
DATA_DIR=./data

# Where raw uploaded files are persisted before ingestion.
UPLOAD_DIR=./data/uploads

# ChromaDB persistent-client directory (vector index + payload).
CHROMA_DIR=./data/chroma

# SQLite file for document metadata and query metrics.
SQLITE_PATH=./data/metadata.db

# ── Ingestion ────────────────────────────────────────────────────────
# Recursive character splitter chunk size (characters, not tokens).
CHUNK_SIZE=512

# Overlap between consecutive chunks. Too low loses context across
# chunk boundaries; too high inflates the index.
CHUNK_OVERLAP=64

# ── Retrieval ────────────────────────────────────────────────────────
# Weights for the hybrid score fusion. Must sum to 1.0.
DENSE_WEIGHT=0.7
SPARSE_WEIGHT=0.3

# Number of candidates fetched from each channel before reranking.
# Higher values trade latency for recall.
RETRIEVAL_TOP_K=20

# Final number of chunks returned to the LLM / caller.
RERANK_TOP_K=5

# ── Agent orchestration ──────────────────────────────────────────────
# Hard cap on iterations through the LangGraph router. Prevents the
# fallback logic from looping indefinitely.
AGENT_MAX_ITERATIONS=3
